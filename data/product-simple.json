{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/product.simple.json",
  "title": "Simplified Product",
  "type": "object",
  "required": [
    "id",
    "name",
    "category"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique product identifier"
    },

    "name": {
      "type": "string"
    },

    "description": {
      "type": "string"
    },

    "category": {
      "type": "string"
    },

    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },

    "hsCode": {
      "type": "string",
      "description": "Harmonized System code"
    },

    "technicalCore": {
      "type": "object",
      "description": "Condensed representation of underlying technical structure",
      "properties": {
        "domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "principles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "materials": {
          "type": "array",
          "items": { "type": "string" }
        },
        "processes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    },

    "metadata": {
      "type": "object",
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },

  "$defs": {
    "event": {
      "type": "object",
      "required": ["date", "type", "description"],
      "properties": {
        "date": {
          "type": "string",
          "format": "date"
        },
        "type": {
          "type": "string",
          "enum": [
            "invention",
            "innovation",
            "process_improvement",
            "market_entry",
            "regulation",
            "disruption",
            "decline"
          ]
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },

  "additionalProperties": false
}