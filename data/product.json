{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/product.json",
  "title": "Product",
  "type": "object",
  "required": ["id", "name", "category"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the product"
    },

    "name": {
      "type": "string",
      "description": "Canonical name of the product"
    },

    "alternateNames": {
      "type": "array",
      "items": { "type": "string" }
    },

    "description": {
      "type": "string",
      "description": "High-level semantic description"
    },

    "category": {
      "type": "string",
      "description": "Primary classification (e.g., electronics, chemical, service)"
    },

    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },

    "productSpace": {
      "type": "object",
      "description": "Embedding in the product space (economic complexity perspective)",
      "properties": {
        "hsCode": {
          "type": "string",
          "description": "Harmonized System classification"
        },
        "sitcCode": {
          "type": "string"
        },
        "complexityIndex": {
          "type": "number",
          "description": "Economic Complexity Index (ECI/PCI)"
        },
        "relatedProducts": {
          "type": "array",
          "items": { "$ref": "#/$defs/productRef" }
        },
        "upstreamProducts": {
          "type": "array",
          "items": { "$ref": "#/$defs/productRef" }
        },
        "downstreamProducts": {
          "type": "array",
          "items": { "$ref": "#/$defs/productRef" }
        }
      }
    },

    "technicalCore": {
      "type": "object",
      "description": "Underlying technical and scientific basis",
      "properties": {
        "domains": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Relevant technical fields (e.g., semiconductor physics, organic chemistry)"
        },
        "principles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Key scientific/engineering principles"
        },
        "materials": {
          "type": "array",
          "items": { "type": "string" }
        },
        "components": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" }
        },
        "processes": {
          "type": "array",
          "items": { "$ref": "#/$defs/process" }
        },
        "standards": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "functionalProperties": {
      "type": "object",
      "description": "What the product does",
      "additionalProperties": {
        "type": ["number", "string", "boolean"]
      }
    },

    "performanceMetrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metric"
      }
    },

    "economicData": {
      "type": "object",
      "properties": {
        "priceRange": {
          "type": "object",
          "properties": {
            "min": { "type": "number" },
            "max": { "type": "number" },
            "currency": { "type": "string" }
          }
        },
        "marketSize": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "description": "Units used (e.g., units/year, tons/year)"
        }
      }
    },

    "lifecycle": {
      "type": "object",
      "properties": {
        "stage": {
          "type": "string",
          "enum": ["R&D", "Introduction", "Growth", "Maturity", "Decline"]
        },
        "introductionDate": {
          "type": "string",
          "format": "date"
        },
        "obsolescenceDate": {
          "type": "string",
          "format": "date"
        }
      }
    },

    "history": {
      "type": "array",
      "description": "Temporal evolution of the product",
      "items": {
        "$ref": "#/$defs/event"
      }
    },

    "variants": {
      "type": "array",
      "items": { "$ref": "#/$defs/productRef" }
    },

    "relationships": {
      "type": "object",
      "properties": {
        "substitutes": {
          "type": "array",
          "items": { "$ref": "#/$defs/productRef" }
        },
        "complements": {
          "type": "array",
          "items": { "$ref": "#/$defs/productRef" }
        },
        "bundledWith": {
          "type": "array",
          "items": { "$ref": "#/$defs/productRef" }
        }
      }
    },

    "metadata": {
      "type": "object",
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "source": { "type": "string" }
      }
    }
  },

  "$defs": {
    "productRef": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },

    "component": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" }
      }
    },

    "process": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" }
      }
    },

    "metric": {
      "type": "object",
      "required": ["name", "value"],
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      }
    },

    "event": {
      "type": "object",
      "required": ["date", "type", "description"],
      "properties": {
        "date": { "type": "string", "format": "date" },
        "type": {
          "type": "string",
          "enum": [
            "invention",
            "innovation",
            "process_improvement",
            "market_entry",
            "regulation",
            "disruption",
            "decline"
          ]
        },
        "description": { "type": "string" },
        "actors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}