{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/product-space.json",
  "title": "Product Space",
  "type": "object",
  "required": ["metadata", "products"],
  "properties": {

    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "version": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "source": { "type": "string" }
      },
      "additionalProperties": false
    },

    "products": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/product"
      }
    },

    "edges": {
      "type": "array",
      "description": "Relationships between products (product space graph)",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }

  },

  "$defs": {

    "product": {
      "type": "object",
      "required": ["id", "name", "category"],
      "properties": {

        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },

        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },

        "hsCode": { "type": "string" },

        "technicalCore": {
          "type": "object",
          "properties": {
            "domains": {
              "type": "array",
              "items": { "type": "string" }
            },
            "principles": {
              "type": "array",
              "items": { "type": "string" }
            },
            "materials": {
              "type": "array",
              "items": { "type": "string" }
            },
            "processes": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },

        "history": {
          "type": "array",
          "items": { "$ref": "#/$defs/event" }
        },

        "metadata": {
          "type": "object",
          "properties": {
            "createdAt": { "type": "string", "format": "date-time" },
            "updatedAt": { "type": "string", "format": "date-time" },
            "source": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "edge": {
      "type": "object",
      "required": ["source", "target", "type"],
      "properties": {
        "source": {
          "type": "string",
          "description": "Product ID"
        },
        "target": {
          "type": "string",
          "description": "Product ID"
        },
        "type": {
          "type": "string",
          "enum": [
            "related",
            "upstream",
            "downstream",
            "substitute",
            "complement"
          ]
        },
        "weight": {
          "type": "number",
          "description": "Strength of relationship (e.g., proximity)"
        }
      },
      "additionalProperties": false
    },

    "event": {
      "type": "object",
      "required": ["date", "type", "description"],
      "properties": {
        "date": { "type": "string", "format": "date" },
        "type": {
          "type": "string",
          "enum": [
            "invention",
            "innovation",
            "process_improvement",
            "market_entry",
            "regulation",
            "disruption",
            "decline"
          ]
        },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    }

  },

  "additionalProperties": false
}